  author = {Moher, David and Hopewell, Sally and Schulz, Kenneth F. and Montori, Victor and G{\o}tzsche, Peter C. and Devereaux, P. J. and Elbourne, Diana and Egger, Matthias and Altman, Douglas G.},
  year = 2010,
